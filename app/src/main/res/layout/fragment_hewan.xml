<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- SEARCH -->

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:queryHint="Cari hewan..."
        android:iconifiedByDefault="false"/>

    <!-- REGION -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupHewan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSemua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semua"
                android:checked="true"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSumatra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sumatra"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipJawa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jawa"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKalimantan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalimantan"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSulawesi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sulawesi"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPapua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Papua"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMaluku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maluku"
                android:checkable="true"/>

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- LIST -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHewan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>